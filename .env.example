# =============================================================================
# OUTBOUND ENGINE - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# Note: Brand-specific settings (including API keys) come from database
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# LLM - Global Default (Brand-specific overrides in database)
# =============================================================================
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your-groq-api-key-here
LLM_MODEL=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.2

# =============================================================================
# OPTIONAL - System Configuration
# =============================================================================
LOG_LEVEL=info
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# OPTIONAL - Webhooks
# =============================================================================
RESEND_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# SEARCH API KEYS - Per-brand in brand_profiles.config JSONB field
# =============================================================================
# Store in database (brand_profiles.config):
# {
#   "zenserp_api_key": "your-zenserp-key",
#   "serper_api_key": "your-serper-key",
#   "hunter_api_key": "your-hunter-key",
#   "apollo_api_key": "your-apollo-key"
# }
# =============================================================================