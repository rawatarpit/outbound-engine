# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=generate-a-random-secret-key-here

# App Settings
LOG_LEVEL=info
PORT=10000
NODE_ENV=production

# CORS (comma-separated domains)
CORS_ORIGIN=https://your-app.netlify.app,http://localhost:5173

# =====================================================
# LLM Configuration (Default - can be overridden per client)
# =====================================================

# Provider: ollama | groq | openai | anthropic | cloudflare
LLM_PROVIDER=ollama

# Model selection (varies by provider)
LLM_MODEL=llama3:8b

# For Ollama (local): http://localhost:11434
# For Groq: leave empty (uses Groq API)
# For OpenAI: https://api.openai.com/v1
# For Anthropic: https://api.anthropic.com
# For Cloudflare: https://gateway.ai.cloudflare.com
LLM_BASE_URL=http://localhost:11434

# API Key (required for groq, openai, anthropic, cloudflare)
LLM_API_KEY=your-api-key-here

# Temperature (0-1)
LLM_TEMPERATURE=0.2

# Alternative env vars for Ollama (backward compatibility)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b