# =============================================================================
# REQUIRED
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# LLM Configuration (Required - using Groq)
# =============================================================================
# Provider: openai, anthropic, groq
LLM_PROVIDER=groq

# Groq API endpoint (don't change this)
LLM_BASE_URL=https://api.groq.com/openai/v1

# Model selection (Groq recommended models)
# llama-3.1-70b-versatile - best overall
# llama-3.1-8b-instant - fastest/cheapest
# mixtral-8x7b-32768 - good balance
LLM_MODEL=llama-3.1-70b-versatile

# Get free API key at https://console.groq.com/keys
LLM_API_KEY=gsk_your-groq-api-key-here

# Temperature (0-1) - lower = more focused, higher = more creative
LLM_TEMPERATURE=0.2

# =============================================================================
# OPTIONAL - Debugging
# =============================================================================
# Logging: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Environment: development, production, test
NODE_ENV=production

# =============================================================================
# OPTIONAL - Webhooks (only if using Resend API for email)
# =============================================================================
# Get from Resend dashboard: https://resend.com/webhooks
# RESEND_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# OPTIONAL - CORS (only if running web server)
# =============================================================================
# CORS_ORIGIN=https://your-domain.com,http://localhost:3000