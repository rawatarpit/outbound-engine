{
  "name": "outbound-engine",
  "version": "2.0.0",
  "description": "Autonomous multi-agent outbound engine (Supabase-backed, IMAP-driven, LLM-integrated, revenue-optimized)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "enrichment": "node dist/enrichment/worker.js",
    "discovery": "node dist/discovery/index.js",
    "discovery:scheduler": "node dist/discovery/scheduler.js",
    "discovery:processor": "node dist/discovery/processor.js",
    "send": "node dist/queue/sendProcessor.js",
    "inbound": "node dist/email/imap.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pm2:discovery": "pm2 start npm --name outbound-discovery -- run discovery",
    "pm2:enrichment": "pm2 start npm --name outbound-enrichment -- run enrichment",
    "pm2:send": "pm2 start npm --name outbound-send -- run send",
    "pm2:inbound": "pm2 start npm --name outbound-inbound -- run inbound",
    "pm2:all": "npm run pm2:discovery && npm run pm2:enrichment && npm run pm2:send && npm run pm2:inbound",
    "pm2:stop": "pm2 delete all"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "imapflow": "^1.0.164",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "pino": "^9.0.0",
    "raw-body": "^3.0.2",
    "resend": "^6.9.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/csv-parse": "^1.1.12",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
